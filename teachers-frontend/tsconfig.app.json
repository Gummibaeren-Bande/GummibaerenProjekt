{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue", "../shared-backend/src/**/*.ts"],
  "exclude": ["src/**/__tests__/*", "../shared-backend/src/__tests__/*.ts"],
  "compilerOptions": {
    "composite": true,
    "verbatimModuleSyntax": false,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
