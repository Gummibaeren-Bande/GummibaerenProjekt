{
  "name": "teachers-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "host": "vite --host",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview --port 8081 --host",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@primevue/themes": "^4.2.4",
    "@tailwindcss/vite": "^4.0.1",
    "dotenv": "^16.4.7",
    "primeicons": "^7.0.0",
    "primevue": "^4.2.5",
    "qrcode": "^1.5.4",
    "socket.io-client": "^4.8.1",
    "tailwindcss": "^4.0.1",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.9.3",
    "@types/qrcode": "^1.5.5",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/eslint-plugin": "1.1.10",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.1.3",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "esbuild": ">=0.25.0",
    "eslint": "^9.14.0",
    "eslint-plugin-vue": "^9.30.0",
    "jsdom": "^25.0.1",
    "npm-run-all2": "^7.0.1",
    "prettier": "^3.3.3",
    "typescript": "~5.6.3",
    "vite": "^6.0.9",
    "vite-plugin-inspect": "^10.1.1",
    "vite-plugin-vue-devtools": "^7.7.1",
    "vitest": "^2.1.9",
    "vue-tsc": "^2.1.10"
  }
}
